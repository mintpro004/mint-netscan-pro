{
  "productName": "NetScan Pro",
  "version": "0.1.0",
  "identifier": "com.netscan.pro",
  "build": {
    "frontendDist": "../src",
    "devUrl": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' tauri://localhost"
    },
    "windows": [
      {
        "title": "NetScan Pro",
        "width": 1000,
        "height": 800
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
